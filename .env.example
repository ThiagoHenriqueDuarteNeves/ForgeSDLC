# ─────────────────────────────────────────────────────────────
# Forge SDLC — variáveis de ambiente (template)
# Copie para .env e preencha. NUNCA commite o .env (ver .gitignore).
# ─────────────────────────────────────────────────────────────

# Banco (Postgres + pgvector) — usado pelo docker-compose e pela API
POSTGRES_USER=forge
POSTGRES_PASSWORD=forge
POSTGRES_DB=forge

# Provider de LLM (DeepSeek V4, formato OpenAI) — ver PRD §3.1.
# A API_KEY fica SÓ aqui, nunca no código nem no compose.
LLM_BASE_URL=https://api.deepseek.com
LLM_API_KEY=
MODEL_GRILL=deepseek-v4-pro
MODEL_EXTRATOR=deepseek-v4-pro
MODEL_CRITICO=deepseek-v4-pro
MODEL_CONSOLIDADOR=deepseek-v4-flash
MODEL_REFINADOR=deepseek-v4-pro
MODEL_ANALISTA=deepseek-v4-pro
MODEL_ARQUITETO=deepseek-v4-pro
MODEL_DESIGNER=deepseek-v4-pro
MODEL_FATIADOR=deepseek-v4-pro

# ── Hardening (Fase 8 / PRD §6-Segurança) ──────────────────────────────────
# Tetos duros por run. 0 = sem limite (apenas dev). Estourar aborta o run (402).
MAX_TOKENS_PER_RUN=0
MAX_USD_PER_RUN=0
# Máx. de iterações por estágio (crítico↔refinador, refatiar).
MAX_ITER_PER_STAGE=3
# Timeout por chamada de tool (rag_busca), em segundos. 0 = desligado.
TOOL_TIMEOUT_S=0
# Limite de páginas por arquivo (PDF) na ingestão. 0 = desligado.
MAX_PAGES_PER_FILE=200
# Scanner de conteúdo não-confiável: true liga o LLM Guard (uv pip install
# llm-guard). Desligado usa o fallback heurístico (sempre presente).
USE_LLM_GUARD=false
# Auth: token exigido no header X-API-Token. Vazio = auth desligada (dev).
API_TOKEN=
# Rate limit por IP (requisições/minuto). 0 = desligado.
RATE_LIMIT_PER_MIN=0

# Observabilidade de custo (Fase 7). Preço por modelo em USD por 1M tokens,
# como JSON {"modelo": [entrada, saida]}. Vazio = usa os defaults de
# metrics.DEFAULT_PRICES. Ajuste conforme a tabela do provider.
LLM_PRICES_JSON=

# CORS (origens da web em dev). No Docker a web sobe na 3000; local pode
# cair na 3001 se a 3000 estiver ocupada.
CORS_ORIGINS=http://localhost:3000,http://localhost:3001

# Observabilidade (Langfuse) — ver PRD §3 e docker-compose.langfuse.yml.
# DEIXE VAZIO para rodar sem tracing (a API funciona normalmente).
# Para ligar: suba o Langfuse (docker compose -f docker-compose.langfuse.yml up -d),
# abra http://localhost:3001, crie um projeto e cole as chaves abaixo.
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
LANGFUSE_HOST=http://localhost:3001
# (API dentro do Docker? use LANGFUSE_HOST=http://host.docker.internal:3001)
