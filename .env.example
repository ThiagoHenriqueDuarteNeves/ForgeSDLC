# ─────────────────────────────────────────────────────────────
# Forge SDLC — variáveis de ambiente (template)
# Copie para .env e preencha. NUNCA commite o .env (ver .gitignore).
# ─────────────────────────────────────────────────────────────

# Banco (Postgres + pgvector) — usado pelo docker-compose e pela API
POSTGRES_USER=forge
POSTGRES_PASSWORD=forge
POSTGRES_DB=forge

# Provider de LLM (DeepSeek V4, formato OpenAI) — ver PRD §3.1.
# A API_KEY fica SÓ aqui, nunca no código nem no compose.
LLM_BASE_URL=https://api.deepseek.com
LLM_API_KEY=
MODEL_GRILL=deepseek-v4-pro
MODEL_EXTRATOR=deepseek-v4-pro
MODEL_CRITICO=deepseek-v4-pro
MODEL_CONSOLIDADOR=deepseek-v4-flash
MODEL_REFINADOR=deepseek-v4-pro
MODEL_ANALISTA=deepseek-v4-pro
MODEL_ARQUITETO=deepseek-v4-pro
MODEL_DESIGNER=deepseek-v4-pro
MODEL_FATIADOR=deepseek-v4-pro

# Tetos duros por run (Fase 8). 0 = sem limite (apenas dev).
MAX_TOKENS_PER_RUN=0
MAX_USD_PER_RUN=0

# CORS (origens da web em dev). No Docker a web sobe na 3000; local pode
# cair na 3001 se a 3000 estiver ocupada.
CORS_ORIGINS=http://localhost:3000,http://localhost:3001

# Observabilidade (Langfuse) — ver PRD §3 e docker-compose.langfuse.yml.
# DEIXE VAZIO para rodar sem tracing (a API funciona normalmente).
# Para ligar: suba o Langfuse (docker compose -f docker-compose.langfuse.yml up -d),
# abra http://localhost:3001, crie um projeto e cole as chaves abaixo.
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
LANGFUSE_HOST=http://localhost:3001
# (API dentro do Docker? use LANGFUSE_HOST=http://host.docker.internal:3001)
